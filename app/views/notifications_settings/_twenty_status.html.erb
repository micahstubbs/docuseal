<div class="mt-8 mb-4" id="twenty_status">
  <h2 class="text-3xl font-bold mb-4">
    Twenty CRM
  </h2>
  <div class="flex items-center space-x-3">
    <% if !@twenty_status[:configured] %>
      <span class="badge badge-ghost"><%= t('not_configured') %></span>
      <span class="text-sm opacity-70">
        <%= t('set_twenty_crm_url_twenty_crm_api_key_and_twenty_crm_file_field_metadata_id_environment_variables_to_enable') %>
      </span>
    <% elsif @twenty_status[:reachable] %>
      <span class="badge badge-success"><%= t('connected') %></span>
      <span class="text-sm opacity-70">
        <%= @twenty_status[:url] %>
      </span>
    <% else %>
      <span class="badge badge-error"><%= t('unreachable') %></span>
      <span class="text-sm opacity-70">
        <%= @twenty_status[:url] %> — <%= @twenty_status[:error] %>
      </span>
    <% end %>
  </div>
  <% if @twenty_status[:configured] %>
    <p class="text-sm opacity-70 mt-2">
      <%= t('signed_documents_are_automatically_uploaded_to_twenty_crm_when_all_parties_complete_signing') %>
    </p>
  <% end %>
</div>
